# MiniBattle environment template
# Copy this file to .env for local/staging usage.
# Do not commit real secrets.

# Runtime
APP_ENV=local
COMPOSE_PROJECT_NAME=minibattle

# Frontend
FRONTEND_HOST_PORT=3000
REACT_APP_API_BASE=

# API Gateway
API_GATEWAY_HOST_PORT=8000
API_GATEWAY_CORS_ORIGINS=http://localhost:3000

# MongoDB
MONGO_HOST_PORT=27017
MONGO_URL=mongodb://mongo:27017
MONGO_DATABASE=minibattle

# Auth
JWT_SECRET=change-me-use-a-long-random-value
JWT_EXPIRES_IN_HOURS=1

# Service URLs used inside the Docker network
USER_SERVICE_URL=http://user-service:8000
AUTH_SERVICE_URL=http://auth-service:8000
MATCH_SERVICE_URL=http://match-service:8000
GAME_SERVICE_URL=http://game-service:8000
CHAT_SERVICE_URL=http://chat-service:8000
NOTIFICATION_SERVICE_URL=http://notification-service:8000

# Operations
LOG_LEVEL=INFO
HEALTHCHECK_INTERVAL=10s
HEALTHCHECK_TIMEOUT=3s
HEALTHCHECK_RETRIES=5
